# Postgres connection string (Railway provides this automatically when you attach a Postgres plugin)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gf_football

# 32+ character secret for cookie session encryption
SESSION_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars

# Optional bootstrap admin (created on first boot if no users exist)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Optional: where uploaded photos live (defaults to ./public/uploads)
UPLOAD_DIR=./public/uploads

# Pot per player in NZD, used on the prizes page
BUY_IN_NZD=100

# Shared secret for the hourly clanker cron (POST /api/cron/results-sync).
# Set the same value as the CRON_SECRET GitHub Actions repo secret. If unset,
# the cron endpoint rejects every request (fail closed).
CRON_SECRET=change-me-to-a-long-random-cron-token
